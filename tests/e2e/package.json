{
	"name": "@pluv-tests/e2e",
	"version": "0.0.0",
	"sideEffects": false,
	"private": true,
	"type": "module",
	"scripts": {
		"cf:typegen": "wrangler types --env-interface CloudflareEnv ./cf.d.ts",
		"dev": "concurrently \"pnpm:dev:client\" \"pnpm:dev:noop:server:node\" \"pnpm:dev:yjs:server:cloudflare\" \"pnpm:dev:yjs:server:node\" \"pnpm:dev:yjs:server:node-redis\"",
		"dev:client": "next dev --port 3100 --webpack",
		"dev:loro:server:node": "vite-node --config ./vite.server.config.ts ./src/server/loro/node/index.ts -- --port 3112",
		"dev:noop:server:node": "vite-node --config ./vite.server.config.ts ./src/server/noop/node/index.ts -- --port 3122",
		"dev:yjs:server:cloudflare": "wrangler dev --port 3101",
		"dev:yjs:server:node": "vite-node --config ./vite.server.config.ts ./src/server/yjs/node/index.ts -- --port 3102",
		"dev:yjs:server:node-redis": "vite-node --config ./vite.server.config.ts ./src/server/yjs/node-redis/index.ts -- --port 3103",
		"lint": "eslint \"src/**/*.ts*\" --fix --max-warnings 0",
		"db:push": "drizzle-kit push",
		"playwright": "playwright",
		"start": "next start",
		"test": "playwright test",
		"test:noop:node": "playwright test ./src/tests/noop/node/**/*",
		"test:loro:node": "playwright test ./src/tests/loro/node/**/*",
		"test:yjs:cloudflare-kv": "wrangler deploy --dry-run && playwright test ./src/tests/yjs/cloudflare-kv/**/*",
		"test:yjs:cloudflare-sqlite": "wrangler deploy --dry-run && playwright test ./src/tests/yjs/cloudflare-sqlite/**/*",
		"test:yjs:node": "rm -f dev.db && drizzle-kit push && playwright test ./src/tests/yjs/node/**/*",
		"test:yjs:node-redis": "playwright test ./src/tests/yjs/node-redis/**/*",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@blocknote/core": "^0.51.4",
		"@blocknote/mantine": "^0.51.4",
		"@blocknote/react": "^0.51.4",
		"@hono/node-server": "^2.0.4",
		"@lexical/react": "^0.45.0",
		"@lexical/utils": "^0.45.0",
		"@lexical/yjs": "^0.45.0",
		"@pluv/addon-indexeddb": "workspace:^",
		"@pluv/client": "workspace:^",
		"@pluv/crdt-loro": "workspace:^",
		"@pluv/crdt-yjs": "workspace:^",
		"@pluv/io": "workspace:^",
		"@pluv/persistence-cloudflare-transactional-storage": "workspace:^",
		"@pluv/persistence-redis": "workspace:^",
		"@pluv/platform-cloudflare": "workspace:^",
		"@pluv/platform-node": "workspace:^",
		"@pluv/platform-pluv": "workspace:^",
		"@pluv/pubsub-redis": "workspace:^",
		"@pluv/react": "workspace:^",
		"@pluv/types": "workspace:^",
		"@slate-yjs/core": "^1.0.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/common-tags": "^1.8.4",
		"@types/cors": "^2.8.19",
		"@types/ms": "^2.1.0",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"better-sqlite3": "^12.10.0",
		"commander": "^15.0.0",
		"common-tags": "^1.8.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.25",
		"ioredis": "^5.11.1",
		"lexical": "^0.45.0",
		"loro-crdt": "^1.13.6",
		"ms": "^2.1.3",
		"next": "16.2.9",
		"path-to-regexp": "^8.4.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"slate": "^0.124.1",
		"slate-dom": "^0.124.1",
		"slate-react": "^0.124.2",
		"ws": "^8.21.0",
		"yjs": "^13.6.31",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260613.1",
		"@playwright/test": "^1.60.0",
		"@pluv/tsconfig": "workspace:^",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.5.0",
		"eslint-config-pluv": "workspace:^",
		"miniflare": "^4.20260611.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.16",
		"vite-node": "^6.0.0",
		"wrangler": "^4.100.0"
	}
}
