{
  "name": "pluv-monorepo",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "scripts": {
    "build": "turbo run build",
    "build:internal": "turbo run build --filter=./internal/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "changeset": "changeset",
    "clean": "turbo run clean && rm -rf node_modules",
    "commit": "cz",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --parallel --filter=./apps/*",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "services:start": "docker compose up -d",
    "services:stop": "docker compose down",
    "test": "turbo run test",
    "test:e2e": "turbo run test --filter=@pluv-tests/e2e...",
    "test:types": "turbo run test --filter=@pluv-tests/types...",
    "typecheck": "turbo run typecheck",
    "turbo": "turbo",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18"
  }
}
