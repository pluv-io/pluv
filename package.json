{
  "name": "pluv-monorepo",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "scripts": {
    "build": "turbo run build",
    "build:internal": "turbo run build --filter=./internal/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "changeset": "changeset",
    "clean": "turbo run clean && rm -rf node_modules",
    "commit": "cz",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --parallel --filter=./apps/*",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "services:start": "docker compose up -d",
    "services:stop": "docker compose down",
    "test": "turbo run test",
    "test:e2e": "turbo run test --filter=@pluv-tests/e2e...",
    "test:types": "turbo run test --filter=@pluv-tests/types...",
    "typecheck": "turbo run typecheck",
    "turbo": "turbo",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14"
  }
}
